# Copia este archivo como .env y sustituye todos los valores de ejemplo.
# No subas el archivo .env real al repositorio.

# Seguridad y administrador inicial
JWT_SECRET=generar_una_clave_larga_aleatoria
ADMIN_EMAIL=admin@example.org
ADMIN_PASSWORD=cambiar_por_una_contrasena_segura

# Puerto de la aplicación dentro del host. Para Nginx, se publica solo en localhost.
APP_PORT=3101

# Ruta pública cuando Nginx sirve la aplicación en http://servidor/comites/
# Para servirla en la raíz, usa VITE_BASE_PATH=/ y deja VITE_API_URL vacío.
VITE_BASE_PATH=/comites/
VITE_API_URL=/comites
